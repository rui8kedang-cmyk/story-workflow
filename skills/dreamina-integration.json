{
  "name": "dreamina-integration",
  "description": "Dreamina (即梦) AI 视频生成集成模块，支持 Seedance 2.0 全能参考模式",
  "version": "1.0.0",
  "author": "xurui01",
  "created": "2026-04-14",
  "updated": "2026-04-14",
  "categories": ["video-generation", "ai-tools", "dreamina"],
  "features": {
    "text2video": {
      "enabled": true,
      "description": "文本到视频生成",
      "models": ["seedance2.0", "seedance2.0fast", "seedance2.0_vip", "seedance2.0fast_vip"],
      "default_model": "seedance2.0fast",
      "duration_range": [4, 15],
      "ratios": ["1:1", "3:4", "16:9", "4:3", "9:16", "21:9"],
      "resolution": "720p"
    },
    "multimodal2video": {
      "enabled": true,
      "description": "全能参考视频生成（多模态输入）",
      "models": ["seedance2.0", "seedance2.0fast", "seedance2.0_vip", "seedance2.0fast_vip"],
      "default_model": "seedance2.0fast",
      "input_limits": {
        "images": 9,
        "videos": 3,
        "audio": 3
      },
      "audio_duration": [2, 15],
      "duration_range": [4, 15],
      "ratios": ["1:1", "3:4", "16:9", "4:3", "9:16", "21:9"],
      "resolution": "720p"
    },
    "image2video": {
      "enabled": true,
      "description": "单图到视频生成",
      "models": ["seedance2.0", "seedance2.0fast", "seedance2.0_vip", "seedance2.0fast_vip"]
    },
    "multiframe2video": {
      "enabled": true,
      "description": "多帧故事视频生成",
      "models": ["seedance2.0", "seedance2.0fast", "seedance2.0_vip", "seedance2.0fast_vip"]
    }
  },
  "workflow_integration": {
    "eddie_star": {
      "enabled": true,
      "description": "《大发明家艾迪·星》动画系列专用工作流",
      "prompt_template": "儿童3D动画风格，{story_content}，明亮色彩，温馨搞笑，适合6-12岁儿童观看",
      "recommended_settings": {
        "model": "seedance2.0fast",
        "duration": 8,
        "ratio": "16:9",
        "resolution": "720p"
      }
    },
    "general_animation": {
      "enabled": true,
      "description": "通用动画视频生成",
      "prompt_template": "{content}，动画风格，流畅动作，高质量渲染",
      "recommended_settings": {
        "model": "seedance2.0",
        "duration": 10,
        "ratio": "16:9",
        "resolution": "720p"
      }
    }
  },
  "cli_commands": {
    "login": "dreamina login --headless",
    "check_credit": "dreamina user_credit",
    "text2video": "dreamina text2video --prompt=\"{prompt}\" --model_version={model} --duration={duration} --ratio={ratio}",
    "multimodal2video": "dreamina multimodal2video --image {images} --video {videos} --audio {audio} --prompt=\"{prompt}\" --model_version={model} --duration={duration} --ratio={ratio}",
    "query_result": "dreamina query_result --submit_id={submit_id}",
    "list_tasks": "dreamina list_task"
  },
  "requirements": {
    "dreamina_cli": ">= fa7ede2",
    "path_setup": "C:\\Users\\xurui01\\.dreamina_cli must be in PATH",
    "account": "VIP maestro account required for full features"
  },
  "examples": {
    "eddie_star_episode": {
      "story": "艾迪的自动作业检查器",
      "prompt": "儿童3D动画风格，小学生艾迪发明了自动作业检查器，用旧手机摄像头和放大镜制作，机器会发出叮咚声提示错误，搞笑温馨场景，明亮色彩，适合6-12岁儿童观看",
      "settings": {
        "model": "seedance2.0fast",
        "duration": 8,
        "ratio": "16:9"
      }
    },
    "multimodal_reference": {
      "description": "使用多张参考图生成视频",
      "inputs": {
        "images": ["character_design.png", "scene_background.png"],
        "audio": ["background_music.mp3"]
      },
      "prompt": "根据参考图生成连贯动画视频",
      "settings": {
        "model": "seedance2.0",
        "duration": 12,
        "ratio": "16:9"
      }
    }
  }
}